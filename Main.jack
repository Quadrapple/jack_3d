 let x_t = x_t + (view_3x3m_02 * z) + ((view_3x3m_02 * posFrac_3v_2) / 256); 

 let y_t = (view_3x3m_10 * x) + ((view_3x3m_10 * posFrac_3v_0) / 256); 
