    function void getCurrentRoom() {
        var int room_addr, room_mdl_count, room_prt_count;
        let room_addr = 9000;
        let current_room = 0;

        while(room_addr < room_addr_end) {
            if((pos_3v_0 < (Memory.peek(room_addr+1) + 1)) & (pos_3v_0 > (Memory.peek(room_addr) - 1)) &
                (pos_3v_1 < (Memory.peek(room_addr+3) + 1)) & (pos_3v_1 > (Memory.peek(room_addr+2) - 1)) &
                (pos_3v_2 < (Memory.peek(room_addr+5) + 1)) & (pos_3v_2 > (Memory.peek(room_addr+4) - 1))) {

                let current_room = room_addr;
                return;
            }


            let room_mdl_count = Memory.peek(room_addr + 6);
            let room_addr = room_addr + 7 + room_mdl_count;

            let room_prt_count = Memory.peek(room_addr);
            let room_addr = room_addr + 1 + (room_prt_count * 11);
        }

        let current_room = 0;
        return;
    }

    function void transformPoints() {
        var int room_addr, prt_addr, room_prt_addr_end, room_mdl_count, room_prt_count;

        if(current_room = 0) {
            let room_addr = 9000;
            while(room_addr < room_addr_end) {

                do Main.transformPointsInRoom(room_addr);


                let room_mdl_count = Memory.peek(room_addr + 6);
                let room_addr = room_addr + 7 + room_mdl_count;

                let room_prt_count = Memory.peek(room_addr);
                let room_addr = room_addr + 1 + (room_prt_count * 11);
            }

        } else {
            let room_addr = current_room;

            do Main.transformPointsInRoom(room_addr);

            let room_mdl_count = Memory.peek(room_addr + 6);
            let room_addr = room_addr + 7 + room_mdl_count;

            let room_prt_count = Memory.peek(room_addr);
            let prt_addr = room_addr + 1;
            let room_prt_addr_end = prt_addr + (room_prt_count * 11);

            do Main.breakpoint();
            while(prt_addr < room_prt_addr_end) {
                do Main.transformPointsInRoom(Memory.peek(prt_addr+9));
                let prt_addr = prt_addr + 11;
            }
        }
        return;
    }

    function void transformPointsInRoom(int room_addr) {
        var int room_mdl_addr, room_mdls_end, room_prts_end;
        var int room_prt_count;
        var int mdl_addr, prt_addr;
        var int model_prototype, model_prototype_end, points3d_addr_local;

        var int x, y, z;
        var int x_t, y_t, z_t;
        var int x_offset, y_offset, z_offset;
        var int x_scale, y_scale, z_scale;

        var int x_tr, y_tr, z_tr, x_bl, y_bl, z_bl;

        let room_mdl_addr = (room_addr + 7);
        let room_mdls_end = room_mdl_addr + Memory.peek(room_addr + 6);

        while(room_mdl_addr < room_mdls_end) {
            let mdl_addr = Memory.peek(room_mdl_addr);


            let model_prototype = 16168;
            let model_prototype_end = model_prototype + (3*8);




            let points3d_addr_local = Memory.peek(mdl_addr + 7);

            let x_scale = Memory.peek(mdl_addr + 1 + 0);
            let y_scale = Memory.peek(mdl_addr + 1 + 1);
            let z_scale = Memory.peek(mdl_addr + 1 + 2);
            let x_offset = Memory.peek(mdl_addr + 4 + 0);
            let y_offset = Memory.peek(mdl_addr + 4 + 1);
            let z_offset = Memory.peek(mdl_addr + 4 + 2);


            while(model_prototype < model_prototype_end) {
                let x = ((x_scale * (Memory.peek(model_prototype)) - pos_3v_0)) + x_offset;
                let y = ((y_scale * (Memory.peek(model_prototype + 1)) - pos_3v_1)) + y_offset;
                let z = ((z_scale * (Memory.peek(model_prototype + 2)) - pos_3v_2)) + z_offset;

                let z_t = (view_3x3m_20 * x) + ((view_3x3m_20 * posFrac_3v_0) / 256);
 let z_t = z_t + (view_3x3m_21 * y); 
 let z_t = z_t + (view_3x3m_22 * z) + ((view_3x3m_22 * posFrac_3v_2) / 256); 

 let x_t = (view_3x3m_00 * x) + ((view_3x3m_00 * posFrac_3v_0) / 256); 
 let x_t = x_t + (view_3x3m_02 * z) + ((view_3x3m_02 * posFrac_3v_2) / 256); 

 let y_t = (view_3x3m_10 * x) + ((view_3x3m_10 * posFrac_3v_0) / 256); 
 let y_t = y_t + (view_3x3m_11 * y);
 let y_t = y_t + (view_3x3m_12 * z) + ((view_3x3m_12 * posFrac_3v_2) / 256);

                do Memory.poke(points3d_addr_local, x_t / 2); 
 do Memory.poke(points3d_addr_local+1, y_t / 2); 
 do Memory.poke(points3d_addr_local+2, z_t / 2);

                let model_prototype = model_prototype + 3;
                let points3d_addr_local = points3d_addr_local + 3;
            }
            let room_mdl_addr = room_mdl_addr + 1;
        }

        let room_prt_count = Memory.peek(room_mdl_addr);
        let prt_addr = room_mdl_addr + 1;
        let room_prts_end = prt_addr + (room_prt_count * 11);



        while(prt_addr < room_prts_end) {
            let points3d_addr_local = Memory.peek(prt_addr+10);

            let x_tr = Memory.peek(prt_addr);
            let y_tr = Memory.peek(prt_addr + 1);
            let z_tr = Memory.peek(prt_addr + 2);
            let x_bl = Memory.peek(prt_addr + 3);
            let y_bl = Memory.peek(prt_addr + 4);
            let z_bl = Memory.peek(prt_addr + 5);



            let x = x_tr - pos_3v_0;
            let y = y_tr - pos_3v_1;
            let z = z_tr - pos_3v_2;
            let z_t = (view_3x3m_20 * x) + ((view_3x3m_20 * posFrac_3v_0) / 256);
 let z_t = z_t + (view_3x3m_21 * y); 
 let z_t = z_t + (view_3x3m_22 * z) + ((view_3x3m_22 * posFrac_3v_2) / 256); 

