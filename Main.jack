    function void bufferEdges() {
        var int room_addr, prt_addr, room_prt_addr_end, room_mdl_count, room_prt_count;

        if(current_room = 0) {
            let room_addr = 9000;
            while(room_addr < room_addr_end) {
                do Main.bufferEdgesInRoom(room_addr);


                let room_mdl_count = Memory.peek(room_addr + 6);
                let room_addr = room_addr + 7 + room_mdl_count;

                let room_prt_count = Memory.peek(room_addr);
                let room_addr = room_addr + 1 + (room_prt_count * 11);
            }

        } else {
            let room_addr = current_room;
            do Main.bufferEdgesInRoom(room_addr);

            let room_mdl_count = Memory.peek(room_addr + 6);
            let room_addr = room_addr + 7 + room_mdl_count;

            let room_prt_count = Memory.peek(room_addr);
            let prt_addr = room_addr + 1;
            let room_prt_addr_end = prt_addr + (room_prt_count * 11);

            while(prt_addr < room_prt_addr_end) {
                do Main.breakpoint();
                do Main.bufferEdgesInRoomPortaled(prt_addr);
                let prt_addr = prt_addr + 11;
            }
        }

        return;
    }

