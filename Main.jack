            let points3d_addr_local = points3d_addr_local + 3;


            let x = x_bl - pos_3v_0;
            let z = z_bl - pos_3v_2;
            let z_t = (view_3x3m_20 * x) + ((view_3x3m_20 * posFrac_3v_0) / 256);
