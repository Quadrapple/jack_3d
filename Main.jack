 let y_t = y_t + (view_3x3m_12 * z) + ((view_3x3m_12 * posFrac_3v_2) / 256);
            do Memory.poke(points3d_addr_local, x_t / 2); 
 do Memory.poke(points3d_addr_local+1, y_t / 2); 
 do Memory.poke(points3d_addr_local+2, z_t / 2);
            let points3d_addr_local = points3d_addr_local + 3;


            let y = y_bl - pos_3v_1;
            let z_t = (view_3x3m_20 * x) + ((view_3x3m_20 * posFrac_3v_0) / 256);
 let z_t = z_t + (view_3x3m_21 * y); 
 let z_t = z_t + (view_3x3m_22 * z) + ((view_3x3m_22 * posFrac_3v_2) / 256); 

 let x_t = (view_3x3m_00 * x) + ((view_3x3m_00 * posFrac_3v_0) / 256); 
 let x_t = x_t + (view_3x3m_02 * z) + ((view_3x3m_02 * posFrac_3v_2) / 256); 

 let y_t = (view_3x3m_10 * x) + ((view_3x3m_10 * posFrac_3v_0) / 256); 
