    function void pollKeyboard() {
        var int key;
        let key = Keyboard.keyPressed();





        if(key & 64) {
            if(key & 16) {
                if (key = 87) {
                    let velocity_3v_0 = velocity_3v_0 - sinYaw;
                    let velocity_3v_2 = velocity_3v_2 + cosYaw;
                } else {
                    if (key = 83) {
                        let velocity_3v_0 = velocity_3v_0 + sinYaw;
                        let velocity_3v_2 = velocity_3v_2 - cosYaw;
                    }
                }
            } else {
                if (key = 65) {
                    let velocity_3v_0 = velocity_3v_0 - cosYaw;
                    let velocity_3v_2 = velocity_3v_2 - sinYaw;
                } else {
                    if (key = 68) {
                        let velocity_3v_0 = velocity_3v_0 + cosYaw;
                        let velocity_3v_2 = velocity_3v_2 + sinYaw;
                    }
                }
            }
        } else {





            if(key & 2) {

                if (key = 130) {
                    let yaw = (yaw + 1) & 255;
                } else {
                    if (key = 131) {
                        let pitch = (pitch - 1) & 255;
                    }
                }
            } else {

                if(key & 128) {
                    if (key = 132) {
                        let yaw = (yaw - 1) & 255;
                    } else {
                        if (key = 133) {
                            let pitch = (pitch + 1) & 255;
                        }
                    }
                } else {

                    if (key = 32) {





                        if(pos_3v_1 < (2 + 1)) {
                            let velocity_3v_1 = velocity_3v_1 - 196;
                        }


                    } else {





                    }
                }

            }
        }




        if(((pos_3v_1 < 2) | (posFrac_3v_1 > -128 & pos_3v_1 = 2))) {
            let posFrac_3v_1 = -128;
            let pos_3v_1 = 2;
            let velocity_3v_1 = 0;
        } else {
            if((velocity_3v_1 > 128) | ~(pos_3v_1 > 2)) {

            } else {
                let velocity_3v_1 = velocity_3v_1 + 24;
            }
        }


        let posFrac_3v_0 = posFrac_3v_0 + (velocity_3v_0 / 4);
        let velocity_3v_0 = velocity_3v_0 / 4;

        let posFrac_3v_1 = posFrac_3v_1 + velocity_3v_1;

        let posFrac_3v_2 = posFrac_3v_2 + (velocity_3v_2 / 4);
        let velocity_3v_2 = velocity_3v_2 / 4;

        if(posFrac_3v_0 < -255) {
            let posFrac_3v_0 = posFrac_3v_0 + 255;
            let pos_3v_0 = pos_3v_0 + 1;
        } else {
            if(posFrac_3v_0 > 1) {
                let posFrac_3v_0 = posFrac_3v_0 - 255;
                let pos_3v_0 = pos_3v_0 - 1;
            }
        }

        if(posFrac_3v_1 < -255) {
            let posFrac_3v_1 = posFrac_3v_1 + 255;
            let pos_3v_1 = pos_3v_1 + 1;
        } else {
            if(posFrac_3v_1 > 1) {
                let posFrac_3v_1 = posFrac_3v_1 - 255;
                let pos_3v_1 = pos_3v_1 - 1;
            }
        }

        if(posFrac_3v_2 < -255) {
            let posFrac_3v_2 = posFrac_3v_2 + 255;
            let pos_3v_2 = pos_3v_2 + 1;
        } else {
            if(posFrac_3v_2 > -1) {
